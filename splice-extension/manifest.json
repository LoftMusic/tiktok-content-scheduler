{
  "manifest_version": 3,
  "name": "Splice Audio Downloader",
  "version": "1.0",
  "description": "Download audio samples from Splice.com",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://splice.com/*",
    "https://*.splice.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://splice.com/*", "https://*.splice.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}